{
  "name": "omero-pos",
  "version": "1.0.0",
  "description": "Omero POS — Electron desktop wrapper",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron .",
    "copy:html": "cp main/splash.html dist/main/splash.html",
    "build": "tsc && npm run copy:html && electron-builder",
    "build:win": "tsc && npm run copy:html && electron-builder --win",
    "build:mac": "tsc && npm run copy:html && electron-builder --mac",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.0.0"
  }
}
